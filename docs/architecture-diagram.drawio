<mxfile host="app.diagrams.net" type="device">
  <diagram name="Data and usage flow" id="flow">
    <mxGraphModel dx="1100" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="t1" value="Chess + Agentforce — data and usage flow (one play-and-coach turn)" style="text;html=1;align=center;fontStyle=1;fontSize=16;fontColor=#001E5B;" vertex="1" parent="1">
          <mxGeometry x="120" y="10" width="560" height="30" as="geometry" />
        </mxCell>

        <mxCell id="n1" value="1. Player signs in (Devise — email + password)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5A6B82;fontColor=#001E5B;" vertex="1" parent="1">
          <mxGeometry x="210" y="60" width="360" height="40" as="geometry" />
        </mxCell>
        <mxCell id="n2" value="2. Browser GETs a short-lived RS256 JWT from /identity_token" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F4FB;strokeColor=#0D9DDA;fontColor=#001E5B;" vertex="1" parent="1">
          <mxGeometry x="210" y="120" width="360" height="40" as="geometry" />
        </mxCell>
        <mxCell id="n3" value="3. setIdentityToken — Salesforce verifies the JWT and binds the conversation to the Contact" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6E4FF;strokeColor=#001E5B;fontColor=#001E5B;" vertex="1" parent="1">
          <mxGeometry x="190" y="180" width="400" height="50" as="geometry" />
        </mxCell>
        <mxCell id="n4" value="4. Player makes a move — Stockfish replies — Rails persists FEN + PGN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F4FB;strokeColor=#0D9DDA;fontColor=#001E5B;" vertex="1" parent="1">
          <mxGeometry x="190" y="260" width="400" height="50" as="geometry" />
        </mxCell>

        <mxCell id="L1" value="5a. Player asks the embedded MIAW widget a question" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6E4FF;strokeColor=#001E5B;fontColor=#001E5B;" vertex="1" parent="1">
          <mxGeometry x="30" y="380" width="320" height="50" as="geometry" />
        </mxCell>
        <mxCell id="L2" value="6a. Chess_Coach checks subscription (Apex — Contact.Is_Subscribed__c)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6E4FF;strokeColor=#001E5B;fontColor=#001E5B;" vertex="1" parent="1">
          <mxGeometry x="15" y="450" width="350" height="50" as="geometry" />
        </mxCell>
        <mxCell id="Ldec" value="Subscribed?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#F4F6F9;strokeColor=#5A6B82;fontColor=#001E5B;" vertex="1" parent="1">
          <mxGeometry x="110" y="530" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="Lyes" value="Pull live board (/coach/game_state) — engine tools — grounded coaching" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E9F7EF;strokeColor=#1B7F4B;fontColor=#0B3D24;" vertex="1" parent="1">
          <mxGeometry x="10" y="650" width="360" height="60" as="geometry" />
        </mxCell>
        <mxCell id="Lno" value="Subscription-required upsell (no analysis)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3D6;strokeColor=#B45309;fontColor=#3A2A00;" vertex="1" parent="1">
          <mxGeometry x="10" y="740" width="360" height="50" as="geometry" />
        </mxCell>

        <mxCell id="R1" value="5b. App auto-posts the completed move to /agent_chat" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F4FB;strokeColor=#0D9DDA;fontColor=#001E5B;" vertex="1" parent="1">
          <mxGeometry x="450" y="380" width="320" height="50" as="geometry" />
        </mxCell>
        <mxCell id="R2" value="6b. Rails checks Subscription.active? via SOQL (ECA token)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F4FB;strokeColor=#0D9DDA;fontColor=#001E5B;" vertex="1" parent="1">
          <mxGeometry x="435" y="450" width="350" height="50" as="geometry" />
        </mxCell>
        <mxCell id="Rdec" value="Subscribed?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#F4F6F9;strokeColor=#5A6B82;fontColor=#001E5B;" vertex="1" parent="1">
          <mxGeometry x="530" y="530" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="Ryes" value="Agent API (bypassUser) — engine tools — grounded auto-comment" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E9F7EF;strokeColor=#1B7F4B;fontColor=#0B3D24;" vertex="1" parent="1">
          <mxGeometry x="430" y="650" width="360" height="60" as="geometry" />
        </mxCell>
        <mxCell id="Rno" value="Upsell reply — agent never called (0 credits)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3D6;strokeColor=#B45309;fontColor=#3A2A00;" vertex="1" parent="1">
          <mxGeometry x="430" y="740" width="360" height="50" as="geometry" />
        </mxCell>

        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5A6B82;" edge="1" parent="1" source="n1" target="n2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5A6B82;" edge="1" parent="1" source="n2" target="n3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5A6B82;" edge="1" parent="1" source="n3" target="n4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" value="MIAW coach (reactive)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#001E5B;fontColor=#334155;" edge="1" parent="1" source="n4" target="L1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" value="Headless coach (proactive)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#0D9DDA;fontColor=#334155;" edge="1" parent="1" source="n4" target="R1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5A6B82;" edge="1" parent="1" source="L1" target="L2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5A6B82;" edge="1" parent="1" source="L2" target="Ldec"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e8" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#1B7F4B;fontColor=#1B7F4B;" edge="1" parent="1" source="Ldec" target="Lyes"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e9" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#B45309;fontColor=#B45309;" edge="1" parent="1" source="Ldec" target="Lno"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="190" y="730" /></Array></mxGeometry></mxCell>
        <mxCell id="e10" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5A6B82;" edge="1" parent="1" source="R1" target="R2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e11" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5A6B82;" edge="1" parent="1" source="R2" target="Rdec"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e12" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#1B7F4B;fontColor=#1B7F4B;" edge="1" parent="1" source="Rdec" target="Ryes"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e13" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#B45309;fontColor=#B45309;" edge="1" parent="1" source="Rdec" target="Rno"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="610" y="730" /></Array></mxGeometry></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram name="Component landscape" id="land">
    <mxGraphModel dx="1100" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="cRails" value="Rails app — Heroku" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#0D9DDA;dashed=1;verticalAlign=top;fontStyle=1;fontColor=#0D9DDA;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="300" height="370" as="geometry" />
        </mxCell>
        <mxCell id="cSF" value="Salesforce — chess-agent org" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#001E5B;dashed=1;verticalAlign=top;fontStyle=1;fontColor=#001E5B;" vertex="1" parent="1">
          <mxGeometry x="430" y="120" width="320" height="320" as="geometry" />
        </mxCell>
        <mxCell id="cMCP" value="chess-mcp-coach — Heroku" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#B45309;dashed=1;verticalAlign=top;fontStyle=1;fontColor=#B45309;" vertex="1" parent="1">
          <mxGeometry x="430" y="470" width="320" height="120" as="geometry" />
        </mxCell>

        <mxCell id="P" value="Player (browser)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#5A6B82;fontColor=#001E5B;" vertex="1" parent="1">
          <mxGeometry x="160" y="40" width="180" height="50" as="geometry" />
        </mxCell>

        <mxCell id="BOARD" value="Chess board (Stockfish + chess.js)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F4FB;strokeColor=#0D9DDA;fontColor=#001E5B;" vertex="1" parent="1">
          <mxGeometry x="60" y="160" width="260" height="50" as="geometry" />
        </mxCell>
        <mxCell id="IDTOK" value="/identity_token (RS256 JWT minter)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F4FB;strokeColor=#0D9DDA;fontColor=#001E5B;" vertex="1" parent="1">
          <mxGeometry x="60" y="230" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="GAMESTATE" value="/coach/game_state (live board pull)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F4FB;strokeColor=#0D9DDA;fontColor=#001E5B;" vertex="1" parent="1">
          <mxGeometry x="60" y="290" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="AGENTCHAT" value="/agent_chat (headless turns)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F4FB;strokeColor=#0D9DDA;fontColor=#001E5B;" vertex="1" parent="1">
          <mxGeometry x="60" y="350" width="260" height="40" as="geometry" />
        </mxCell>
        <mxCell id="SUBSVC" value="Subscription + SalesforceQuery (SOQL via ECA token)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F4FB;strokeColor=#0D9DDA;fontColor=#001E5B;" vertex="1" parent="1">
          <mxGeometry x="60" y="410" width="260" height="50" as="geometry" />
        </mxCell>

        <mxCell id="MIAW" value="MIAW channel + User Verification" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6E4FF;strokeColor=#001E5B;fontColor=#001E5B;" vertex="1" parent="1">
          <mxGeometry x="450" y="160" width="280" height="50" as="geometry" />
        </mxCell>
        <mxCell id="COACH" value="Chess_Coach (Apex / MIAW agent)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6E4FF;strokeColor=#001E5B;fontColor=#001E5B;" vertex="1" parent="1">
          <mxGeometry x="450" y="230" width="280" height="40" as="geometry" />
        </mxCell>
        <mxCell id="AGENTAPI" value="Agent API — Chess_Coach_MCP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D6E4FF;strokeColor=#001E5B;fontColor=#001E5B;" vertex="1" parent="1">
          <mxGeometry x="450" y="300" width="280" height="40" as="geometry" />
        </mxCell>
        <mxCell id="CONTACT" value="Contact.Is_Subscribed__c" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#E9F7EF;strokeColor=#1B7F4B;fontColor=#0B3D24;boundedLbl=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="360" width="180" height="70" as="geometry" />
        </mxCell>

        <mxCell id="ENGINE" value="Stockfish MCP server (/mcp + REST facade)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3D6;strokeColor=#B45309;fontColor=#3A2A00;" vertex="1" parent="1">
          <mxGeometry x="450" y="510" width="280" height="50" as="geometry" />
        </mxCell>

        <mxCell id="x1" value="plays" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5A6B82;fontColor=#334155;" edge="1" parent="1" source="P" target="BOARD"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="x2" value="MIAW widget" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5A6B82;fontColor=#334155;" edge="1" parent="1" source="P" target="MIAW"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="x3" value="mint JWT" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5A6B82;fontColor=#334155;" edge="1" parent="1" source="BOARD" target="IDTOK"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="x4" value="setIdentityToken" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5A6B82;fontColor=#334155;" edge="1" parent="1" source="IDTOK" target="MIAW"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="x5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#001E5B;" edge="1" parent="1" source="MIAW" target="COACH"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="x6" value="pull live board" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5A6B82;fontColor=#334155;" edge="1" parent="1" source="COACH" target="GAMESTATE"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="x7" value="engine tools" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5A6B82;fontColor=#334155;" edge="1" parent="1" source="COACH" target="ENGINE"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="x8" value="check subscription" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5A6B82;fontColor=#334155;" edge="1" parent="1" source="COACH" target="CONTACT"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="x9" value="auto-comment" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5A6B82;fontColor=#334155;" edge="1" parent="1" source="BOARD" target="AGENTCHAT"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="x10" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#0D9DDA;" edge="1" parent="1" source="AGENTCHAT" target="SUBSVC"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="x11" value="SOQL" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5A6B82;fontColor=#334155;" edge="1" parent="1" source="SUBSVC" target="CONTACT"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="x12" value="send message" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5A6B82;fontColor=#334155;" edge="1" parent="1" source="AGENTCHAT" target="AGENTAPI"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="x13" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#B45309;" edge="1" parent="1" source="AGENTAPI" target="ENGINE"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
