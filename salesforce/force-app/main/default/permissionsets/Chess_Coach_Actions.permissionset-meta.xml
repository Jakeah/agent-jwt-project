<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Chess Coach Actions</label>
    <description>Apex class access for the Chess Coach agent's actions (player-name lookup + engine-grounded analysis via the chess REST facade). Assigned to the Einstein Agent User.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <classAccesses>
        <apexClass>ChessCoachGetPlayerName</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>ChessCoachClient</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>ChessCoachAnalyzePosition</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>ChessCoachBestMove</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>ChessCoachJudgeMove</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <classAccesses>
        <apexClass>ChessCoachNameOpening</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <!-- Live-game pull for the verified coach (continuity-trap fix): the agent calls this each turn
         to read the player's CURRENT board from Rails, keyed by the verified Contact's email. -->
    <classAccesses>
        <apexClass>ChessCoachGetLiveGame</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <!-- Deterministic subscription gate: the agent calls this in before_reasoning to decide whether
         to coach (paid) or show the upsell. Reads Contact.Is_Subscribed__c (FLS granted below). -->
    <classAccesses>
        <apexClass>ChessCoachCheckSubscription</apexClass>
        <enabled>true</enabled>
    </classAccesses>
    <!-- Access to the external credential principal behind the ChessCoachApi Named Credential,
         so the agent user's Apex callouts can authenticate to the chess REST facade. -->
    <externalCredentialPrincipalAccesses>
        <externalCredentialPrincipal>ChessMCP-MCPAuthentication</externalCredentialPrincipal>
        <enabled>true</enabled>
    </externalCredentialPrincipalAccesses>
    <!-- Access to the ChessLiveGame principal so the agent user's callout to the Rails live-game
         endpoint can resolve the bearer-header principal (the verified-coach pull). -->
    <externalCredentialPrincipalAccesses>
        <externalCredentialPrincipal>ChessLiveGame-ChessLiveGamePrincipal</externalCredentialPrincipal>
        <enabled>true</enabled>
    </externalCredentialPrincipalAccesses>
    <!-- Read on UserExternalCredential is required at callout time to resolve the principal. -->
    <objectPermissions>
        <object>UserExternalCredential</object>
        <allowRead>true</allowRead>
        <allowCreate>false</allowCreate>
        <allowEdit>false</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>false</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <!-- Contact READ + View All so the agent's ChessCoachCheckSubscription can find the player's
         Contact (and read Is_Subscribed__c). The Einstein Agent User profile has NO Contact access at
         all, and these Contacts are owned by the integration user (not the agent), so under a Private
         OWD object-Read alone wouldn't surface them — View All is required. Without this the
         subscription SOQL returns zero rows and the gate fails closed (upsells EVERY user). This is
         the first agent action that actually reads Contact: get_player_name keyed on the null
         ContactId so it never ran, and get_live_game keys on the prechat email (no Contact read). -->
    <objectPermissions>
        <object>Contact</object>
        <allowRead>true</allowRead>
        <allowCreate>false</allowCreate>
        <allowEdit>false</allowEdit>
        <allowDelete>false</allowDelete>
        <viewAllRecords>true</viewAllRecords>
        <modifyAllRecords>false</modifyAllRecords>
    </objectPermissions>
    <!-- FLS read on the MessagingSession game-context fields so the agent can read them as
         @MessagingSession.Chess_*__c (populated by the Omni-Flow from the hidden prechat fields). -->
    <fieldPermissions>
        <field>MessagingSession.Chess_FEN__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>MessagingSession.Chess_Player_Email__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>MessagingSession.Chess_PGN__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>MessagingSession.Chess_Turn__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>MessagingSession.Chess_Move_Count__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <fieldPermissions>
        <field>MessagingSession.Chess_Status__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
    <!-- FLS read on the Contact subscription flag so ChessCoachCheckSubscription can read it
         (custom fields aren't readable by default; the standard Contact.Email needs no entry). -->
    <fieldPermissions>
        <field>Contact.Is_Subscribed__c</field>
        <readable>true</readable>
        <editable>true</editable>
    </fieldPermissions>
</PermissionSet>
