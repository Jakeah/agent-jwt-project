<?xml version="1.0" encoding="UTF-8"?>
<!--
  Base URL for the verified-coach live-game pull. Apex (ChessCoachGetLiveGame) calls
  callout:ChessLiveGame/coach/game_state?email=... ; the ChessLiveGame External Credential injects
  the bearer header. Points at the Rails app on Heroku (the source of truth for the live board),
  NOT the chess-mcp engine — this reads the persisted game, it doesn't run Stockfish.
-->
<NamedCredential xmlns="http://soap.sforce.com/2006/04/metadata">
    <allowMergeFieldsInBody>false</allowMergeFieldsInBody>
    <allowMergeFieldsInHeader>true</allowMergeFieldsInHeader>
    <calloutStatus>Enabled</calloutStatus>
    <description>Rails app base URL for the verified MIAW coach to pull the player's live game state (continuity-trap fix). Auth via the ChessLiveGame External Credential (bearer header).</description>
    <generateAuthorizationHeader>true</generateAuthorizationHeader>
    <label>ChessLiveGame</label>
    <namedCredentialParameters>
        <parameterName>Url</parameterName>
        <parameterType>Url</parameterType>
        <parameterValue>https://chess-agent-jwt-95c105a581a5.herokuapp.com</parameterValue>
    </namedCredentialParameters>
    <namedCredentialParameters>
        <externalCredential>ChessLiveGame</externalCredential>
        <parameterName>ExternalCredential</parameterName>
        <parameterType>Authentication</parameterType>
    </namedCredentialParameters>
    <namedCredentialType>SecuredEndpoint</namedCredentialType>
</NamedCredential>
