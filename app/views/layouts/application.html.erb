<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Agent Jwt Project" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Agent Jwt Project">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <%# For signed-in users, the whole body is the Agentforce controller's scope: it injects the
      MIAW bootstrap, verifies the user on ready, seeds live game context as hidden prechat
      fields, and (because the sign-out button lives inside this scope) clears the verified
      session on sign-out. Config comes from the deployment registry — SOMA/MOMA stays a config
      change. Gating on user_signed_in? means /identity_token always has a Devise session. %>
  <% if user_signed_in? %><% deployment = current_agent_deployment %><% end %>
  <body class="bg-slate-50 text-slate-900 min-h-screen"
        <% if user_signed_in? %>
        data-controller="agentforce"
        data-agentforce-org-id-value="<%= deployment.org_id %>"
        data-agentforce-deployment-name-value="<%= deployment.deployment_name %>"
        data-agentforce-site-url-value="<%= deployment.site_url %>"
        data-agentforce-scrt2-url-value="<%= deployment.scrt2_url %>"
        data-agentforce-script-url-value="<%= "#{deployment.site_url}/assets/js/bootstrap.min.js" %>"
        data-agentforce-deployment-value="<%= deployment.name %>"
        <% end %>>
    <nav class="bg-slate-900 text-white">
      <div class="container mx-auto px-5 py-3 flex items-center justify-between">
        <%= link_to "♞ Chess + Agentforce", root_path, class: "font-semibold text-lg" %>
        <div class="text-sm">
          <% if user_signed_in? %>
            <span class="text-slate-300 mr-3"><%= current_user.email %></span>
            <%# End the verified chat session before the Devise session is destroyed. %>
            <%= button_to "Sign out", destroy_user_session_path, method: :delete,
                  class: "underline hover:text-slate-300",
                  form: { data: { action: "submit->agentforce#endSession" } } %>
          <% else %>
            <%= link_to "Sign in", new_user_session_path, class: "underline hover:text-slate-300" %>
          <% end %>
        </div>
      </div>
    </nav>

    <main class="container mx-auto mt-8 px-5">
      <% if notice %>
        <p class="bg-emerald-100 text-emerald-900 rounded px-4 py-2 mb-4"><%= notice %></p>
      <% end %>
      <% if alert %>
        <p class="bg-rose-100 text-rose-900 rounded px-4 py-2 mb-4"><%= alert %></p>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
