<%# Resolve the MIAW deployment once, up top, so both the <head> resource hints and the <body>
    agentforce controller values can reuse it (one registry lookup). %>
<% agent_deployment = current_agent_deployment if user_signed_in? %>
<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Agent Jwt Project" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Agent Jwt Project">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%# The signed-in player's email, for the MIAW coach: passed as a hidden prechat field so the
        agent can pull the live game by email (the reliable path; @MessagingEndUser.ContactId arrives
        null in agent context). Only rendered when authenticated. %>
    <% if user_signed_in? %><meta name="chess-player-email" content="<%= current_user.email %>"><% end %>

    <%= yield :head %>

    <%# Inter — the app's typeface (modern, highly legible at UI sizes). %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <%# MIAW widget load optimization: warm DNS+TLS to the chat hosts (Experience site, SCRT2
        messaging, org My Domain) and let the browser fetch the bootstrap during HTML parse, so the
        widget's heavy init starts with connections already open instead of all-cold. crossorigin is
        required or the actual credentialed fetches open a second socket and waste the hint. The bulk
        of widget load is platform-side; this trims the app-controllable front of it. %>
    <% if user_signed_in? && agent_deployment&.miaw? %>
      <% miaw_preconnect_origins(agent_deployment).each do |origin| %>
        <link rel="preconnect" href="<%= origin %>" crossorigin>
        <link rel="dns-prefetch" href="<%= origin %>">
      <% end %>
      <link rel="preload" as="script" crossorigin href="<%= "#{agent_deployment.site_url}/assets/js/bootstrap.min.js" %>">
    <% end %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <%# For signed-in users, the whole body is the Agentforce controller's scope: it injects the
      MIAW bootstrap, verifies the user on ready, seeds live game context as hidden prechat
      fields, and (because the sign-out button lives inside this scope) clears the verified
      session on sign-out. Config comes from the deployment registry — SOMA/MOMA stays a config
      change. Gating on user_signed_in? means /identity_token always has a Devise session. %>
  <% deployment = agent_deployment %><%# resolved once at the top of the template (reused by the head hints) %>
  <%# Auth pages (logged-out) get the aurora backdrop + no chrome; signed-in pages get the app shell. %>
  <body class="font-sans text-ink-900 min-h-screen flex flex-col <%= user_signed_in? ? "bg-slate-50" : "" %>"
        <%= "data-auth" unless user_signed_in? %>
        <% if user_signed_in? %>
        data-controller="agentforce"
        data-agentforce-org-id-value="<%= deployment.org_id %>"
        data-agentforce-deployment-name-value="<%= deployment.deployment_name %>"
        data-agentforce-site-url-value="<%= deployment.site_url %>"
        data-agentforce-scrt2-url-value="<%= deployment.scrt2_url %>"
        data-agentforce-script-url-value="<%= "#{deployment.site_url}/assets/js/bootstrap.min.js" %>"
        data-agentforce-deployment-value="<%= deployment.name %>"
        <% end %>>
    <% if user_signed_in? %>
      <nav class="sticky top-0 z-40 bg-ink-950/95 backdrop-blur border-b border-white/5 text-white">
        <div class="max-w-6xl mx-auto px-5 h-14 flex items-center justify-between">
          <%= link_to root_path, class: "flex items-center gap-2 font-display font-bold text-[15px] tracking-tight group" do %>
            <span class="grid place-items-center w-8 h-8 rounded-lg bg-brand-600 text-white text-lg shadow-sm group-hover:bg-brand-500 transition">♞</span>
            <span>Chess<span class="text-brand-300"> Coach</span></span>
          <% end %>
          <div class="flex items-center gap-3">
            <span class="hidden sm:grid place-items-center w-8 h-8 rounded-full bg-white/10 text-brand-200 text-xs font-semibold uppercase">
              <%= current_user.email.first(2) %>
            </span>
            <span class="hidden sm:inline text-sm text-slate-300"><%= current_user.email %></span>
            <%# End the verified chat session before the Devise session is destroyed. %>
            <%= button_to "Sign out", destroy_user_session_path, method: :delete,
                  class: "text-sm font-medium text-slate-300 hover:text-white rounded-lg px-3 py-1.5 hover:bg-white/10 transition",
                  form: { data: { action: "submit->agentforce#endSession" } } %>
          </div>
        </div>
      </nav>
    <% end %>

    <main class="flex-1 <%= user_signed_in? ? "max-w-6xl mx-auto w-full mt-8 px-5 pb-16" : "" %>">
      <% if notice %>
        <div class="<%= user_signed_in? ? "" : "max-w-md mx-auto px-5 pt-5" %>">
          <p class="flex items-center gap-2 bg-brand-50 text-brand-800 border border-brand-100 rounded-xl px-4 py-2.5 mb-4 text-sm font-medium shadow-card">
            <span class="text-brand-500">✓</span><%= notice %>
          </p>
        </div>
      <% end %>
      <% if alert %>
        <div class="<%= user_signed_in? ? "" : "max-w-md mx-auto px-5 pt-5" %>">
          <p class="flex items-center gap-2 bg-rose-50 text-rose-800 border border-rose-100 rounded-xl px-4 py-2.5 mb-4 text-sm font-medium shadow-card">
            <span class="text-rose-500">!</span><%= alert %>
          </p>
        </div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
